# Azure AI Foundry Configuration
# Reemplaza los valores con tus credenciales reales

# Endpoint de Azure AI Foundry
AZURE_FOUNDRY_ENDPOINT=https://<your-foundry-name>.services.ai.azure.com/

# API Key de Azure AI Foundry
AZURE_FOUNDRY_API_KEY=<your-api-key>

# Modelo a utilizar (opcional, depende de tu deployment)
# AZURE_FOUNDRY_MODEL=gpt-4
# AZURE_FOUNDRY_MODEL_MULTIMODAL=gpt-4-vision
# AZURE_FOUNDRY_MODEL_REASONING=gpt-5

# Configuración de Azure
# AZURE_SUBSCRIPTION_ID=<your-subscription-id>
# AZURE_RESOURCE_GROUP=<your-resource-group>
# AZURE_TENANT_ID=<your-tenant-id>

# Configuración de Web Search (si aplica)
# BING_SEARCH_API_KEY=<your-bing-search-key>
# BING_SEARCH_ENDPOINT=https://<region>.bing.microsoft.com/

# Guardrails Configuration (si aplica)
# GUARDRAILS_ENDPOINT=<your-guardrails-endpoint>
# GUARDRAILS_API_KEY=<your-guardrails-key>
